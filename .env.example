# ProcessGuard Andon environment example
# Copy this file to .env and edit the values before running the app.

# PostgreSQL connection string.
# Windows local example:
# DATABASE_URL="postgresql://processguard:CHANGE_THIS_PASSWORD@localhost:5432/processguard?schema=public"
DATABASE_URL="postgresql://processguard:processguard_dev_password@localhost:5432/processguard?schema=public"

# API/web port. Your M5 firmware currently uses port 5003.
PORT=5003
HOST=0.0.0.0

# Used to sign browser session JWTs. Use a long random value in production.
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# Allow one-click demo role sign-in on /login.
# NODE_ENV=production will refuse to start if this is true.
DEMO_MODE=true

# Serve the built React UI from the API server in production.
SERVE_WEB=true

# Comma-separated allowed browser origins for API/WebSocket requests.
# Use the exact production URL in production. Do not use "*" in production.
CORS_ORIGIN="http://localhost:5173"

# Optional external URL shown in logs/docs.
PUBLIC_URL="http://localhost:5003"

# Timezone used for report date filters and daily trend grouping.
REPORT_TIME_ZONE="America/Chicago"

# Seed behavior. If true, npm run db:seed creates demo data/users/pager tokens.
SEED_DEMO=true

# Optional rate-limit tuning. Defaults are safe for normal internal usage.
# RATE_LIMIT_GLOBAL_MAX=1200
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_PAGER_MAX=120
# RATE_LIMIT_MESSAGE_MAX=30
# RATE_LIMIT_ADMIN_WRITE_MAX=120
# RATE_LIMIT_TIME_WINDOW="1 minute"
# SOCKET_REVALIDATE_MS=300000
