# Local SQLite development mode.
# Copy to .env when you want to run without PostgreSQL:
#   cp .env.sqlite.example .env
#
# This is intentionally separate from .env.example so the PostgreSQL setup
# remains the production/default path.

DATABASE_URL="file:./dev.db"

PORT=5003
HOST=0.0.0.0
JWT_SECRET="local-sqlite-development-secret-change-before-production"
DEMO_MODE=true
SERVE_WEB=true
CORS_ORIGIN="http://localhost:5173"
PUBLIC_URL="http://localhost:5003"
REPORT_TIME_ZONE="America/Chicago"
SEED_DEMO=true
